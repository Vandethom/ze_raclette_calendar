# Copier ce fichier en .env.local et remplir les valeurs Supabase
# (Project Settings > API dans l'interface Supabase)

VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Mot de passe du compte administrateur (pseudo "BlueCheese")
# IMPORTANT : cette valeur sera incluse dans le bundle JS — ne pas y mettre de données sensibles.
# C'est suffisant pour protéger l'accès admin d'un calendrier de guilde.
VITE_ADMIN_PASSWORD=Maroilles

# Optionnel – intégration Discord (à venir)
# VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
